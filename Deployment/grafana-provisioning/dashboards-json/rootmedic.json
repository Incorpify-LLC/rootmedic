{
  "id": null,
  "uid": "rootmedic-main",
  "title": "RootMedic — System Health",
  "description": "Autonomous AI medic — log ingestion, error rates, and live event stream.",
  "tags": ["rootmedic"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },

  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Errors (last 1 h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 10 }
            ]
          },
          "mappings": [],
          "unit": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=~\"systemd-journal|fluent-bit\"} |~ \"(?i)\\\\berror\\\\b|\\\\bfail\\\\b|\\\\bkill\\\\b|\\\\bdenied\\\\b\" [1h]))",
          "legendFormat": "Errors"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Warnings (last 1 h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 20 }
            ]
          },
          "mappings": [],
          "unit": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=~\"systemd-journal|fluent-bit\"} |~ \"(?i)\\\\bwarn\\\\b\" [1h]))",
          "legendFormat": "Warnings"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Log Rate (last 5 m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({job=~\"systemd-journal|fluent-bit\"}[5m]))",
          "legendFormat": "Log/s"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Hosts Reporting",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count(count by (host) (rate({job=~\"systemd-journal|fluent-bit\"}[5m])))",
          "legendFormat": "Hosts"
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Error & Warning Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Warnings" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({job=~\"systemd-journal|fluent-bit\"} |~ \"(?i)\\\\berror\\\\b|\\\\bfail\\\\b|\\\\bkill\\\\b\" [2m]))",
          "legendFormat": "Errors"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({job=~\"systemd-journal|fluent-bit\"} |~ \"(?i)\\\\bwarn\\\\b\" [2m]))",
          "legendFormat": "Warnings"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Log Volume by Host",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (host) (rate({job=~\"systemd-journal|fluent-bit\"}[2m]))",
          "legendFormat": "{{host}}"
        }
      ]
    },

    {
      "id": 7,
      "type": "logs",
      "title": "Live Log Stream  —  Errors, Warnings & Critical Events",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=~\"systemd-journal|fluent-bit\"} |~ \"(?i)error|warning|warn|fail|kill|denied|critical|oom\"",
          "legendFormat": ""
        }
      ]
    }

  ]
}
